DB_USER=dev_user
DB_PASSWORD=Developer123
DB_DSN=localhost:1521/freepdb1

JWT_SECRET_KEY=my-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=1440

USE_ORG_LDAP=false

# Local OpenLDAP
LOCAL_LDAP_URI=ldap://localhost:389
LOCAL_LDAP_BASE_DN=dc=enforcement,dc=local
LOCAL_LDAP_BIND_DN=cn=admin,dc=enforcement,dc=local
LOCAL_LDAP_BIND_PASSWORD=admin
LOCAL_LDAP_USER_BASE=ou=people

# Organization LDAP
ORG_LDAP_URI=ldap://ldap.company.com:389
ORG_LDAP_BASE_DN=dc=company,dc=com
ORG_LDAP_BIND_DN=cn=service-account,ou=service,dc=company,dc=com
ORG_LDAP_BIND_PASSWORD=password
ORG_LDAP_USER_BASE=ou=users

# Email Configuration
USE_ORG_EMAIL_SERVICE=false

# Local SMTP
LOCAL_SMTP_HOST=localhost
LOCAL_SMTP_PORT=1025
LOCAL_SMTP_USERNAME=
LOCAL_SMTP_PASSWORD=

# Splitter API Settings
SPLITTER_BASE_URL=https://api.company.com/email
SPLITTER_NOTIFICATION_TYPE=EMAIL
SPLITTER_API_KEY=splitter-key-123

# OTP Settings
OTP_EXPIRATION_MINUTES=5
OTP_LENGTH=6
OTP_MAX_RETRY=3

# CAPTCHA Settings
CAPTCHA_EXPIRATION_MINUTES=5